<Window x:Class="AccuracyTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Time Recording Accuracy Test"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                   Text="Time Recording Accuracy Test" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Test Duration (seconds):" 
                       Foreground="White" 
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBox x:Name="DurationInput" 
                     Width="80" 
                     Text="60"
                     FontSize="16"
                     VerticalContentAlignment="Center"/>
            <Button x:Name="StartButton" 
                    Content="Start Test" 
                    Margin="20,0,0,0"
                    Padding="20,8"
                    Click="StartButton_Click"/>
        </StackPanel>
        
        <Border Grid.Row="2" 
                Background="#2d2d2d" 
                CornerRadius="8" 
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Status:" Foreground="Gray" FontSize="12"/>
                <TextBlock x:Name="StatusText" 
                           Text="Ready to start test" 
                           Foreground="White" 
                           FontSize="18"
                           Margin="0,5,0,0"/>
                <TextBlock x:Name="TimerText" 
                           Text="" 
                           Foreground="#4CAF50" 
                           FontSize="48"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="3" 
                Background="#2d2d2d" 
                CornerRadius="8" 
                Padding="20">
            <ScrollViewer>
                <TextBlock x:Name="InstructionsText" 
                           Foreground="LightGray" 
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="22">
                    <Run FontWeight="Bold" Foreground="White">Instructions:</Run>
                    <LineBreak/>
                    <LineBreak/>
                    1. Make sure TimeRecordingAgent is running and recording
                    <LineBreak/>
                    2. Set the test duration (e.g., 60 seconds)
                    <LineBreak/>
                    3. Click "Start Test" - keep this window focused!
                    <LineBreak/>
                    4. Wait for the countdown to complete
                    <LineBreak/>
                    5. Check the History window in TimeRecordingAgent
                    <LineBreak/>
                    6. Look for "Time Recording Accuracy Test" entry
                    <LineBreak/>
                    7. Compare recorded time vs expected time
                    <LineBreak/>
                    <LineBreak/>
                    <Run FontWeight="Bold" Foreground="#FFD700">Expected:</Run> The recorded time should be within 5-10 seconds of the test duration (accounting for polling interval).
                </TextBlock>
            </ScrollViewer>
        </Border>
        
        <TextBlock Grid.Row="4" 
                   x:Name="ResultText"
                   Text="" 
                   Foreground="#4CAF50" 
                   FontSize="14"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>
