<Window x:Class="TimeRecordingAgent.App.Dialogs.AiSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Settings - Microsoft Foundry" 
        Height="480" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🤖" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="Microsoft Foundry AI Settings" FontWeight="Bold" FontSize="16"/>
                <TextBlock Text="Configure AI-powered task classification" Foreground="#666666" FontSize="12"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Enable AI -->
        <CheckBox Grid.Row="1" x:Name="EnabledCheckbox" Content="Enable AI Suggestions" 
                  FontWeight="SemiBold" Margin="0,0,0,16"/>
        
        <!-- Endpoint -->
        <StackPanel Grid.Row="2">
            <TextBlock>Endpoint URL:</TextBlock>
            <TextBox x:Name="EndpointTextBox" 
                     ToolTip="The Microsoft Foundry endpoint URL (e.g., https://your-resource.openai.azure.com/)"/>
        </StackPanel>
        
        <!-- API Key -->
        <StackPanel Grid.Row="3">
            <StackPanel Orientation="Horizontal">
                <TextBlock>API Key:</TextBlock>
                <TextBlock Text=" (stored locally)" Foreground="#888888" FontSize="11"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox Grid.Column="0" x:Name="ApiKeyPasswordBox" 
                             ToolTip="Your Microsoft Foundry API key"/>
                <Button Grid.Column="1" x:Name="ShowKeyButton" Content="👁" Width="32" Height="32" 
                        Margin="4,0,0,12" Click="ShowKeyButton_Click" ToolTip="Show/hide API key"/>
            </Grid>
        </StackPanel>
        
        <!-- Model -->
        <StackPanel Grid.Row="4">
            <TextBlock>Model Deployment Name:</TextBlock>
            <ComboBox x:Name="ModelCombo" IsEditable="True" Margin="0,0,0,12" Padding="6">
                <!-- GPT-5 Series -->
                <ComboBoxItem>gpt-5</ComboBoxItem>
                <ComboBoxItem>gpt-5-mini</ComboBoxItem>
                <ComboBoxItem>gpt-5-nano</ComboBoxItem>
                <ComboBoxItem>gpt-5.1</ComboBoxItem>
                <ComboBoxItem>gpt-5.2</ComboBoxItem>
                <!-- Claude Models -->
                <ComboBoxItem>claude-opus-4-5</ComboBoxItem>
                <ComboBoxItem>claude-sonnet-4-5</ComboBoxItem>
                <ComboBoxItem>claude-haiku-4-5</ComboBoxItem>
                <ComboBoxItem>claude-opus-4-1</ComboBoxItem>
                <!-- GPT-4 Series -->
                <ComboBoxItem>gpt-4o</ComboBoxItem>
                <ComboBoxItem>gpt-4o-mini</ComboBoxItem>
                <ComboBoxItem>gpt-4.1</ComboBoxItem>
                <ComboBoxItem>gpt-4.1-mini</ComboBoxItem>
                <ComboBoxItem>gpt-4.1-nano</ComboBoxItem>
                <ComboBoxItem>gpt-4</ComboBoxItem>
                <ComboBoxItem>gpt-35-turbo</ComboBoxItem>
            </ComboBox>
        </StackPanel>
        
        <!-- Status -->
        <Border Grid.Row="5" x:Name="StatusBorder" Background="#FFF3CD" BorderBrush="#FFC107" 
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12" Visibility="Collapsed"
                MinHeight="50">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#856404" 
                       VerticalAlignment="Center"/>
        </Border>
        
        <!-- Info -->
        <Border Grid.Row="6" Background="#F0F0F0" CornerRadius="4" Padding="10" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ℹ️ How to get these settings:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#555555">
                    1. Go to ai.azure.com and create or select a project
                    <LineBreak/>
                    2. Deploy a model (e.g., gpt-4o-mini, gpt-5, or claude-sonnet-4-5)
                    <LineBreak/>
                    3. Copy the endpoint URL and API key from the deployment
                </TextBlock>
            </StackPanel>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="TestButton" Content="Test Connection" Width="110" Height="30" 
                    Margin="0,0,8,0" Click="TestButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" 
                    Margin="0,0,8,0" Click="CancelButton_Click" IsCancel="True"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="30" 
                    Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
