<Window x:Class="TimeRecordingAgent.App.Dialogs.TaskClassificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Classify Task" 
        Height="520" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,8">
            You've been working on this task for 5+ minutes:
        </TextBlock>
        
        <TextBlock Grid.Row="1" x:Name="TaskNameText" TextWrapping="Wrap" Margin="0,0,0,16" 
                   Foreground="#0066CC" FontWeight="SemiBold"/>
        
        <!-- AI Suggestion Banner -->
        <Border Grid.Row="2" x:Name="AiSuggestionBanner" Background="#E7F3FF" BorderBrush="#0078D4" 
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,16" Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="🤖" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="AI Suggestions" FontWeight="SemiBold" Foreground="#0078D4"/>
                </StackPanel>
                <TextBlock x:Name="AiReasoningText" TextWrapping="Wrap" FontStyle="Italic" 
                           Foreground="#555555" FontSize="11"/>
            </StackPanel>
        </Border>
        
        <CheckBox Grid.Row="3" x:Name="IsBillableCheckbox" Content="This is billable work" IsChecked="True" Margin="0,0,0,12"/>
        
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Margin="0,0,0,4">Category:</TextBlock>
            <ComboBox x:Name="CategoryCombo" IsEditable="True">
                <ComboBoxItem>Development</ComboBoxItem>
                <ComboBoxItem>Support</ComboBoxItem>
                <ComboBoxItem>Meeting</ComboBoxItem>
                <ComboBoxItem>Administration</ComboBoxItem>
                <ComboBoxItem>Research</ComboBoxItem>
                <ComboBoxItem>Documentation</ComboBoxItem>
            </ComboBox>
        </StackPanel>
        
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Margin="0,0,0,4">Customer:</TextBlock>
            <ComboBox x:Name="CustomerCombo" IsEditable="True"/>
        </StackPanel>
        
        <StackPanel Grid.Row="6" Margin="0,0,0,16">
            <TextBlock Margin="0,0,0,4">Description:</TextBlock>
            <TextBox x:Name="DescriptionTextBox" TextWrapping="Wrap" AcceptsReturn="True" 
                     Height="60" VerticalScrollBarVisibility="Auto"
                     ToolTip="Brief description of what you're working on"/>
        </StackPanel>
        
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="SkipButton" Content="Skip" Width="80" Height="28" Margin="0,0,8,0" Click="SkipButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="28" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
