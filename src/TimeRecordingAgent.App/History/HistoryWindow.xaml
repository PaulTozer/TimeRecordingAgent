<Window x:Class="TimeRecordingAgent.App.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity History"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <!-- Toolbar row 1: Actions -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
            <Button Content="Approve Selected" Click="ApproveSelected_Click" Margin="0,0,8,0" />
            <Button Content="Mark Pending" Click="MarkPending_Click" Margin="0,0,8,0" />
            <Button Content="Delete Selected" Click="DeleteSelected_Click" Margin="0,0,16,0" />
            <Button Content="Refresh" Click="Refresh_Click" Margin="0,0,16,0" />
            <Button Content="Mark Billable" Click="MarkBillable_Click" Margin="0,0,8,0" />
            <Button Content="Mark Non-Billable" Click="MarkNonBillable_Click" Margin="0,0,16,0" />
            <TextBox Width="120"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding BillableCategoryInput, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Category (e.g., Development, Support)"/>
            <Button Content="Set Category" Click="AssignCategory_Click" Margin="0,0,8,0" />
            <TextBox Width="120"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding GroupNameInput, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Customer name"/>
            <Button Content="Assign Customer" Click="AssignGroup_Click" Margin="0,0,8,0" />
            <Button Content="Clear Customer" Click="ClearGroup_Click" Margin="0,0,8,0" />
            <TextBox Width="200"
                     Margin="16,0,8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding DescriptionInput, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Description of the work"/>
            <Button Content="Set Description" Click="SetDescription_Click" Margin="0,0,8,0" />
        </StackPanel>
        
        <!-- Toolbar row 2: Filters and Column Visibility -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Width="200"
                     Margin="0,0,16,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
            <CheckBox Content="Show pending only"
                      IsChecked="{Binding ShowOnlyUnapproved, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0" />
            <CheckBox Content="Today only"
                      IsChecked="{Binding ShowTodayOnly, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0" />
            <CheckBox Content="Hide &lt; 5 min"
                      IsChecked="{Binding HideUnderFiveMinutes, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0" />
            
            <!-- Column Visibility -->
            <TextBlock Text="Columns:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ColumnConfigs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" 
                                  IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <TextBlock Text="{Binding LastRefreshedText}" VerticalAlignment="Center" Margin="16,0,0,0" />
        </StackPanel>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DataGrid x:Name="HistoryGrid"
                      ItemsSource="{Binding Entries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      Grid.Row="0">
                <!-- Columns are built dynamically in code-behind -->
            </DataGrid>
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <GroupBox Header="Customer Totals" Grid.Column="0" Margin="0,0,4,0">
                    <ListView ItemsSource="{Binding GroupSummaries}" Height="120">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Customer" DisplayMemberBinding="{Binding GroupName}" Width="180" />
                                <GridViewColumn Header="Duration" DisplayMemberBinding="{Binding FormattedDuration}" Width="100" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
                <GroupBox Header="Email Time (Top 20)" Grid.Column="1" Margin="4,0,0,0">
                    <ListView ItemsSource="{Binding EmailSummaries}" Height="120">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Email Subject" DisplayMemberBinding="{Binding Subject}" Width="280" />
                                <GridViewColumn Header="Duration" DisplayMemberBinding="{Binding FormattedDuration}" Width="70" />
                                <GridViewColumn Header="Views" DisplayMemberBinding="{Binding ViewCount}" Width="50" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
